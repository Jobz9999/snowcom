<% content_for :body_class, "communities-show" %>

<div class="mx-auto" style="max-width: 800px;">

  <!-- コミュニティヘッダー -->
  <div class="card shadow-lg mb-4 community-card">
    <div class="card-body">

      <div class="d-flex justify-content-between align-items-start mb-2">
        <h1 class="h3 fw-bold mb-0"><%= @community.name %></h1>

        <div class="d-flex gap-2">
          <% if @community.category.present? %>
            <span class="badge bg-dark"><%= @community.category.name %></span>
          <% end %>

          <% if @community.approval_required? %>
            <span class="badge bg-warning text-dark">承認制</span>
          <% else %>
            <span class="badge bg-success">自動承認</span>
          <% end %>
        </div>
      </div>

      <p class="text-muted mb-3"><%= @community.description %></p>

      <div class="d-flex flex-wrap gap-2 align-items-center">
        <% if @community.user == current_user %>
          <%= link_to "編集", edit_community_path(@community), class: "btn btn-outline-primary btn-sm" %>
          <%= button_to "削除",
              community_path(@community),
              method: :delete,
              form: { data: { turbo_confirm: "本当に削除しますか？" }, class: "d-inline" },
              class: "btn btn-outline-danger btn-sm" %>
        <% end %>

        <% if user_signed_in? %>
          <% membership = @community.memberships.find_by(user: current_user) %>

          <% if membership&.approved? %>
            <%= button_to '退会する',
              community_membership_path(@community),
              method: :delete,
              class: "btn btn-outline-warning btn-sm" %>

          <% elsif membership&.pending? %>
            <span class="badge bg-warning text-dark">承認待ち</span>
            <%= button_to '申請取り消し',
              community_membership_path(@community),
              method: :delete,
              class: "btn btn-outline-secondary btn-sm" %>

          <% else %>
            <%= button_to '参加する',
              community_membership_path(@community),
              method: :post,
              class: "btn btn-dark btn-sm" %>
          <% end %>
        <% end %>
      </div>

    </div>
  </div>

  <!-- 承認リクエスト -->
  <% if @community.user == current_user && @community.approval_required? %>
    <div class="card shadow-sm mb-4 community-card">
      <div class="card-body">
        <h2 class="h5 fw-bold mb-3">参加リクエスト</h2>

        <% if @pending_memberships.present? %>
          <div class="list-group">
            <% @pending_memberships.each do |membership| %>
              <div class="list-group-item d-flex justify-content-between align-items-center">
                <strong><%= membership.user.name %></strong>

                <div class="d-flex gap-2">
                  <%= button_to "承認",
                      approve_community_membership_path(@community, membership),
                      method: :patch,
                      class: "btn btn-success btn-sm" %>

                  <%= button_to "拒否",
                      reject_community_membership_path(@community, membership),
                      method: :delete,
                      form: { data: { turbo_confirm: "拒否しますか？" } },
                      class: "btn btn-outline-danger btn-sm" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-muted mb-0">承認待ちはありません。</p>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- 投稿フォーム -->
  <div class="card shadow-sm mb-4 community-card">
    <div class="card-body">
      <h2 class="h5 fw-bold mb-3">Post Form</h2>

      <% membership = user_signed_in? ? @community.memberships.find_by(user: current_user) : nil %>
      <% can_post = @community.user == current_user || membership&.approved? %>

      <% if can_post %>
        <%= form_with model: [@community, @post], local: true do |f| %>
          <div class="mb-3">
            <%= f.text_area :content,
                rows: 4,
                class: "form-control",
                placeholder: "投稿内容を入力..." %>
          </div>

          <div class="mb-3">
            <%= f.file_field :image, class: "form-control form-control-sm" %>
          </div>

          <%= f.submit '投稿', class: "btn btn-primary" %>
        <% end %>
      <% else %>
        <div class="alert alert-warning mb-0">
          コミュニティ参加後に投稿できます
        </div>
      <% end %>
    </div>
  </div>

  <!-- 投稿一覧 -->
  <h2 class="h5 fw-bold mb-3 px-3 py-2 bg-dark text-white rounded">
    投稿一覧
  </h2>

  <% @posts.each do |post| %>
    <div class="card shadow-sm mb-3 community-card">
      <div class="card-body">

        <div class="d-flex justify-content-between mb-2">
          <strong><%= link_to post.user.name, user_path(post.user), class: "text-decoration-none post-author-link" %></strong>
          <small class="text-muted"><%= post.created_at.strftime('%Y-%m-%d %H:%M') %></small>
        </div>

        <p class="mb-2"><%= post.content %></p>

        <% if post.image.attached? %>
          <%= image_tag post.image.variant(resize_to_limit: [300, 300]), class: "img-fluid rounded mb-2" %>
        <% end %>

        <div class="d-flex align-items-center gap-2 small">
          <% if user_signed_in? %>
            <% if post.liked_by?(current_user) %>
              <%= button_to "♥",
                  community_post_like_path(@community, post),
                  method: :delete,
                  class: "btn btn-link p-0 text-danger like-button",
                  form: { class: "d-inline" } %>
            <% else %>
              <%= button_to "♡",
                  community_post_like_path(@community, post),
                  method: :post,
                  class: "btn btn-link p-0 text-muted like-button",
                  form: { class: "d-inline" } %>
            <% end %>
          <% end %>

          <span class="text-muted"><%= post.likes.count %>いいね</span>
        </div>

      </div>
    </div>
  <% end %>

  <div class="text-center my-3">
    <%= paginate @posts %>
  </div>

  <div class="mt-4">
    <%= link_to '一覧に戻る', communities_path, class: "btn btn-outline-secondary" %>
  </div>

</div>