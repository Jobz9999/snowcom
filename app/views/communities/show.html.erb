<div class="mx-auto" style="max-width: 800px;">
  <!-- コミュニティヘッダー --> 
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h1 class="card-title h2 mb-3"><%= @community.name %></h1>

			<% if @community.approval_required? %>
				<span class="badge bg-warning">承認制コミュニティ</span>
			<% else %>
				<span class="badge bg-success">自動承認コミュニティ</span>
			<% end %>

      <% if @community.category.present? %>
        <p class="text-muted mb-2">
          <span class="badge bg-secondary"><%= @community.category.name %></span>
        </p>
      <% end %>

      <p class="card-text mb-4"><%= @community.description %></p>

      <div class="d-flex flex-wrap gap-2 align-items-center">
        <% if @community.user == current_user %>
          <%= link_to "編集", edit_community_path(@community), class: "btn btn-outline-primary btn-sm" %>
          <%= button_to "削除",
              community_path(@community),
              method: :delete,
              form: { data: { turbo_confirm: "本当に削除しますか？" }, class: "d-inline" },
              class: "btn btn-outline-danger btn-sm" %>
        <% end %>

        <% if user_signed_in? %>
          <% membership = @community.memberships.find_by(user: current_user) %>
          <% if membership&.approved? %>
            <%= button_to 'コミュニティから退出', community_membership_path(@community), method: :delete, class: "btn btn-outline-warning btn-sm" %>
          <% elsif membership&.pending? %>
            <span class="badge bg-warning text-dark">承認待ち</span>
            <%= button_to '申請を取り消す', community_membership_path(@community), method: :delete, class: "btn btn-outline-secondary btn-sm" %>
          <% else %>
            <%= button_to 'コミュニティに参加', community_membership_path(@community), method: :post, class: "btn btn-primary btn-sm" %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <% if @community.user == current_user && @community.approval_required? %>
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <h2 class="h5 card-title mb-3">参加リクエストの承認</h2>

        <% if @pending_memberships.present? %>
          <div class="list-group">
            <% @pending_memberships.each do |membership| %>
              <div class="list-group-item d-flex justify-content-between align-items-center">
                <div class="text-break">
                  <strong><%= membership.user.name %></strong>
                </div>

                <div class="d-flex gap-2">
                  <%= button_to "承認",
                      approve_community_membership_path(@community, membership),
                      method: :patch,
                      class: "btn btn-success btn-sm" %>
                  <%= button_to "拒否",
                      reject_community_membership_path(@community, membership),
                      method: :delete,
                      form: { data: { turbo_confirm: "このリクエストを拒否しますか？" } },
                      class: "btn btn-outline-danger btn-sm" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-muted mb-0">承認待ちのリクエストはありません。</p>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- 投稿フォーム -->
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h2 class="h5 card-title mb-3">投稿</h2>
      <% membership = user_signed_in? ? @community.memberships.find_by(user: current_user) : nil %>
      <% can_post = !@community.approval_required? || @community.user == current_user || membership&.approved? %>

      <% if can_post %>
        <%= form_with model: [@community, @post], local: true do |f| %>
          <div class="mb-3">
            <%= f.text_area :content,
                rows: 4,
                class: "form-control",
                placeholder: "投稿内容を入力..." %>
          </div>
          <div class="mb-3">
            <%= f.file_field :image, class: "form-control form-control-sm" %>
          </div>
          <%= f.submit '投稿', class: "btn btn-primary" %>
        <% end %>
      <% else %>
        <div class="alert alert-warning mb-0">
          承認制コミュニティでは参加（承認）後に投稿できます。
        </div>
      <% end %>
    </div>
  </div>

  <!-- 投稿一覧 -->
  <h2 class="h5 mb-3">投稿一覧</h2>

  <% @posts.each do |post| %>
    <div class="card shadow-sm mb-3 post">
			<div class="card-body">
				<div class="d-flex justify-content-between align-items-start mb-2">
					<strong class="text-break"><%= post.user.email %></strong>
					<small class="text-muted"><%= post.created_at.strftime('%Y-%m-%d %H:%M') %></small>
				</div>

				<p class="card-text text-break mb-2"><%= post.content %></p>

				<% if post.image.attached? %>
					<div class="mb-2">
						<%= image_tag post.image.variant(resize_to_limit: [250, 250]), class: "img-fluid rounded" %>
					</div>
				<% end %>

				<div class="d-flex flex-wrap align-items-center gap-2 small">
					<% if user_signed_in? %>
						<% if post.liked_by?(current_user) %>
							<%= button_to "♥",
									community_post_like_path(@community, post),
									method: :delete,
									class: "btn btn-link p-0 like-button liked text-danger",
									form: { class: "d-inline" } %>
						<% else %>
							<%= button_to "♡",
									community_post_like_path(@community, post),
									method: :post,
									class: "btn btn-link p-0 like-button text-muted",
									form: { class: "d-inline" } %>
						<% end %>
					<% end %>
				<span class="text-muted"><%= post.likes.count %> いいね</span>

					<% if post.user == current_user || @community.user == current_user %>
						<span class="ms-2">
							<% if post.user == current_user %>
								<%= link_to '編集', edit_community_post_path(@community, post), class: "text-decoration-none" %>
							<% end %>

						<%= button_to '削除',
								community_post_path(@community, post),
								method: :delete,
								form: { data: { turbo_confirm: '本当に削除しますか？' }, class: "d-inline" },
								class: "btn btn-link p-0 text-danger text-decoration-none" %>
						</span>
					<% end %>
				</div>
			</div>
    </div>
  <% end %>

  <div class="d-flex justify-content-center my-3">
    <%= paginate @posts %>
  </div>

  <div class="mt-4">
    <%= link_to '一覧に戻る', communities_path, class: "btn btn-outline-secondary" %>
  </div>
</div>