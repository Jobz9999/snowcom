<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-2 mb-3">
  <div>
    <h1 class="h3 mb-0">コミュニティ一覧</h1>
    <p class="text-muted mb-0">興味のあるコミュニティを探して参加してみましょう。</p>
  </div>

  <div class="flex-shrink-0">
    <%= link_to "新規作成", new_community_path, class: "btn btn-outline-primary" %>
  </div>
</div>

<%= form_with url: communities_path, method: :get, local: true, class: "mb-4" do |f| %>
  <div class="row g-2 align-items-end">
    <div class="col-12 col-md-6">
      <%= f.label :keyword, "キーワード", class: "form-label visually-hidden" %>
      <%= f.text_field :keyword,
        value: params[:keyword],
        placeholder: "コミュニティを検索",
        class: "form-control" %>
    </div>

    <div class="col-12 col-md-3">
      <%= f.label :category, "カテゴリ", class: "form-label visually-hidden" %>
      <%= f.select :category,
        Community.categories.keys.map { |k| [k.humanize, k] },
        { include_blank: "すべて", selected: params[:category] },
        { class: "form-select" } %>
    </div>

    <div class="col-12 col-md-3 d-grid">
      <%= f.submit "検索", class: "btn btn-primary" %>
    </div>
  </div>
<% end %>

<% if @communities.any? %>
  <div class="row g-3">
    <% @communities.each do |community| %>
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body d-flex flex-column">
            <div class="d-flex align-items-start justify-content-between gap-2">
              <h2 class="h5 card-title mb-1"><%= community.name %></h2>
              <span class="badge text-bg-light border"><%= community.category.to_s.humanize %></span>
            </div>

            <p class="card-text text-muted mb-3"><%= community.description %></p>

            <div class="mt-auto d-flex align-items-center justify-content-between">
              <small class="text-muted"><%= community.memberships.count %>人参加</small>
              <%= link_to "コミュニティを見る", community_path(community), class: "btn btn-sm btn-primary" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="alert alert-info mb-0">
    条件に一致するコミュニティが見つかりませんでした。検索条件を変更してください。
  </div>
<% end %>