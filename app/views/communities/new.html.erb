<div class="mx-auto" style="max-width: 600px;">
  <div class="card shadow-sm">
    <div class="card-body">

      <h1 class="h4 mb-4">コミュニティ作成</h1>

      <%= form_with model: @community, local: true do |f| %>

        <div class="mb-3">
          <%= f.label :name, "コミュニティ名", class: "form-label" %>
          <%= f.text_field :name, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :description, "説明", class: "form-label" %>
          <%= f.text_area :description, rows: 4, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :category, "カテゴリ", class: "form-label" %>
          <%= f.select :category,
              Community.categories.keys.map { |k| [k, k] },
              { include_blank: "選択してください" },
              class: "form-select" %>
        </div>

        <div class="mt-4">
          <%= f.submit "作成", class: "btn btn-primary" %>
          <%= link_to "戻る", communities_path, class: "btn btn-outline-secondary ms-2" %>
        </div>

      <% end %>

    </div>
  </div>
</div>