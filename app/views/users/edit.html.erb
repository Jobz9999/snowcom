<% content_for :body_class, "users-edit" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5">

      <div class="card shadow-sm">
        <div class="card-body p-4">

          <h1 class="h4 mb-4 text-center">プロフィール編集</h1>

          <%= form_with model: @user, local: true do |f| %>

            <div class="mb-3">
              <%= f.label :name, "ユーザー名", class: "form-label" %>
              <%= f.text_field :name, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= f.label :profile, "自己紹介", class: "form-label" %>
              <%= f.text_area :profile, rows: 4, class: "form-control" %>
            </div>

            <div class="d-grid mt-4">
              <%= f.submit "更新する", class: "btn btn-primary" %>
            </div>

          <% end %>

          <div class="mt-4 text-center">
            <%= link_to "戻る", user_path(@user), class: "btn btn-outline-secondary" %>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>