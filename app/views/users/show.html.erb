<% content_for :body_class, "users-show" %>

<div class="row">

  <!-- 左カラム -->
  <div class="col-lg-4 mb-4">

    <!-- プロフィール -->
    <div class="card shadow-sm mb-4 community-card user-profile-card">
      <div class="card-body d-flex flex-column">
        <h2 class="h6 fw-bold mb-3 px-3 py-2 bg-dark text-white rounded">
            プロフィール
        </h2>

        <h1 class="user-profile-card__name h5 fw-bold mb-0">
          <%= @user.name.presence || "名前未設定" %>
        </h1>

        <div class="user-profile-card__section mt-3">
          <span class="user-profile-card__label">自己紹介</span>
          <% if @user.profile.present? %>
            <div class="user-profile-card__bio-shell">
              <%= simple_format(@user.profile, { class: "user-profile-card__bio mb-0" }) %>
            </div>
          <% else %>
            <div class="user-profile-card__bio-shell user-profile-card__bio-shell--empty">
              <p class="user-profile-card__bio user-profile-card__bio--placeholder mb-0">自己紹介が未設定です</p>
            </div>
          <% end %>
        </div>

        <% if current_user == @user %>
          <div class="user-profile-card__actions mt-auto pt-3">
            <%= link_to "プロフィールを編集",
                edit_user_path(@user),
                class: "btn btn-primary btn-sm rounded-pill px-4 user-profile-card__edit" %>
          </div>
        <% end %>

      </div>
    </div>

    <!-- 参加コミュニティ -->
    <div class="card shadow-sm mb-4 community-card">
      <div class="card-body">
        <h2 class="h6 fw-bold mb-3 px-3 py-2 bg-dark text-white rounded">
          参加コミュニティ
        </h2>

        <% if @communities.any? %>
          <% @communities.each do |community| %>
            <div class="mb-2">
              <%= link_to community.name, community_path(community), class: "text-decoration-none" %>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted small">なし</p>
        <% end %>
      </div>
    </div>

    <!-- 作成コミュニティ -->
    <div class="card shadow-sm community-card">
      <div class="card-body">
        <h2 class="h6 fw-bold mb-3 px-3 py-2 bg-dark text-white rounded">
          作成コミュニティ
        </h2>

        <% if @my_communities.any? %>
          <% @my_communities.each do |community| %>
            <div class="mb-3 p-2 border rounded d-flex align-items-center justify-content-between gap-2">
              <div class="fw-bold min-w-0 flex-grow-1">
                <%= link_to community.name,
                    community_path(community),
                    class: "text-decoration-none text-truncate d-block" %>
              </div>

              <div class="d-flex gap-2 flex-shrink-0">
                <%= link_to "編集",
                    edit_community_path(community),
                    class: "btn btn-outline-primary btn-sm" %>

                <%= button_to "削除",
                    community_path(community),
                    method: :delete,
                    data: { turbo_confirm: "本当に削除しますか？" },
                    form: { class: "d-inline" },
                    class: "btn btn-outline-danger btn-sm" %>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted small">なし</p>
        <% end %>

      </div>
    </div>
  </div>

  <!-- 右カラム -->

  <div class="col-lg-8">

    <div class="card shadow-sm community-card">
      <div class="card-body">

        <h2 class="h5 fw-bold mb-3 px-3 py-2 bg-dark text-white rounded">
          自分の投稿
        </h2>

        <% if @posts.any? %>
          <% @posts.each do |post| %>

            <div class="border-bottom mb-3 pb-2 d-flex justify-content-between align-items-end">

              <!-- 左（投稿内容） -->
              <div>
                <p class="mb-1"><%= post.content %></p>
                <small class="text-muted">
                  <%= post.created_at.strftime('%Y-%m-%d %H:%M') %>
                </small>
              </div>

              <!-- 右下（コミュニティ名） -->
              <div>
                <%= link_to post.community.name,
                    community_path(post.community),
                    class: "badge bg-success text-decoration-none" %>
              </div>
            </div>

          <% end %>
        <% else %>
          <p class="text-muted">投稿はありません</p>
        <% end %>

      </div>
    </div>
  </div>
</div>
