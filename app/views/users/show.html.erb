<% content_for :body_class, "users-show" %>

<div class="row">

  <!-- 左カラム -->
  <div class="col-lg-4 mb-4">

    <!-- プロフィール -->
    <div class="card shadow-sm mb-4 community-card">
      <div class="card-body d-flex flex-column">

        <div class="text-center">
          <h1 class="h5 fw-bold mb-2"><%= @user.name %></h1>

          <p class="text-muted small">
            <%= @user.profile.presence || "自己紹介が未設定です" %>
          </p>
        </div>

        <% if current_user == @user %>
          <div class="mt-auto text-end">
            <%= link_to "プロフィール編集",
                edit_user_path(@user),
                class: "btn btn-primary btn-sm" %>
          </div>
        <% end %>

      </div>
    </div>

    <!-- 参加コミュニティ -->
    <div class="card shadow-sm mb-4 community-card">
      <div class="card-body">
        <h2 class="h6 fw-bold mb-3">参加コミュニティ</h2>

        <% if @communities.any? %>
          <% @communities.each do |community| %>
            <div class="mb-2">
              <%= link_to community.name, community_path(community), class: "text-decoration-none" %>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted small">なし</p>
        <% end %>
      </div>
    </div>

    <!-- 作成コミュニティ -->
    <div class="card shadow-sm community-card">
      <div class="card-body">
        <h2 class="h6 fw-bold mb-3">作成コミュニティ</h2>

        <% if @my_communities.any? %>
          <% @my_communities.each do |community| %>
            <div class="mb-3 p-2 border rounded">

              <div class="fw-bold">
                <%= link_to community.name, community_path(community), class: "text-decoration-none" %>
              </div>

              <div class="mt-2 d-flex gap-2">
                <%= link_to "編集",
                    edit_community_path(community),
                    class: "btn btn-outline-primary btn-sm" %>

                <%= button_to "削除",
                    community_path(community),
                    method: :delete,
                    data: { turbo_confirm: "本当に削除しますか？" },
                    form: { class: "d-inline" },
                    class: "btn btn-outline-danger btn-sm" %>
              </div>

            </div>
          <% end %>
        <% else %>
          <p class="text-muted small">なし</p>
        <% end %>

      </div>
    </div>
  </div>

  <!-- 右カラム -->

  <div class="col-lg-8">

    <div class="card shadow-sm community-card">
      <div class="card-body">

        <h2 class="h5 fw-bold mb-3 px-3 py-2 bg-dark text-white rounded">
          自分の投稿
        </h2>

        <% if @posts.any? %>
          <% @posts.each do |post| %>

            <div class="border-bottom mb-3 pb-2 d-flex justify-content-between align-items-end">

              <!-- 左（投稿内容） -->
              <div>
                <p class="mb-1"><%= post.content %></p>
                <small class="text-muted">
                  <%= post.created_at.strftime('%Y-%m-%d %H:%M') %>
                </small>
              </div>

              <!-- 右下（コミュニティ名） -->
              <div>
                <%= link_to post.community.name,
                    community_path(post.community),
                    class: "badge bg-success text-decoration-none" %>
              </div>
            </div>

          <% end %>
        <% else %>
          <p class="text-muted">投稿はありません</p>
        <% end %>

      </div>
    </div>
  </div>
</div>
