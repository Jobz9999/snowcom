<!DOCTYPE html>
<html>
  <head>
    <title>Snowcom</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%= favicon_link_tag('favicon.ico')%>
  </head>

  <body class="<%= content_for?(:body_class) ? yield(:body_class) : '' %>">
    <nav class="navbar navbar-expand-lg navbar-dark app-navbar">
      <div class="container">

        <%= link_to root_path, class: "navbar-brand d-flex align-items-center gap-2" do %>
          <%= image_tag "favicon.ico", alt: "", height: 32, width: 32, class: "flex-shrink-0 app-navbar-logo", aria: { hidden: true } %>
          <span class="app-navbar-brand-text">snowcom</span>
        <% end %>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#globalNav" aria-controls="globalNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="globalNav">
          <div class="navbar-nav ms-auto align-items-lg-center gap-lg-2">

            <%= link_to "コミュニティ一覧", communities_path, class: "nav-link app-nav-link" %>
            <%= link_to "新規コミュニティ作成", new_community_path, class: "nav-link app-nav-link" %>

            <% if user_signed_in? %>

              <%= link_to "マイページ", user_path(current_user), class: "nav-link app-nav-link" %>

              <%= link_to "ログアウト",
                  destroy_user_session_path,
                  data: { turbo_method: :delete },
                  class: "btn btn-outline-light btn-sm px-3 ms-lg-2 mt-2 mt-lg-0 app-nav-btn-outline" %>
            
            <% else %>
              <%= link_to "ログイン", new_user_session_path, class: "btn btn-outline-light btn-sm px-3 ms-lg-2 mt-2 mt-lg-0 app-nav-btn-outline" %>
              <%= link_to "新規登録", new_user_registration_path, class: "btn btn-info btn-sm px-3 mt-2 mt-lg-0 app-nav-btn-filled" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>
    
    <% if notice || alert %>
      <div class="<%= content_for?(:full_width) ? 'flash-overlay' : 'container mt-3' %>">
        <% if notice %>
          <div class="alert alert-success js-auto-dismiss-flash mb-0">
            <%= notice %>
          </div>
        <% end %>

        <% if alert %>
          <div class="alert alert-danger js-auto-dismiss-flash mb-0">
            <%= alert %>
          </div>
        <% end %>
      </div>
    <% end %>

    <main class="<%= content_for?(:full_width) ? '' : 'container mt-4' %>">
      <%= yield %>
    </main>

    <footer class="border-top mt-5 py-3 bg-dark bg-opacity-75">
      <div class="container text-center text-white">
        <small>Copyright © 2026 snowcom</small>
      </div>
    </footer>

  </body>
</html>
