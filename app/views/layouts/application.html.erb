<!DOCTYPE html>
<html>
  <head>
    <title>Snowcom</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= content_for?(:body_class) ? yield(:body_class) : '' %>">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">

        <%= link_to "Snowcom", root_path, class: "navbar-brand" %>

        <div class="navbar-nav ms-auto">

          <%= link_to "コミュニティ一覧", communities_path, class: "nav-link" %>
          <%= link_to "新規コミュニティ作成", new_community_path, class: "nav-link" %>

          <% if user_signed_in? %>

            <%= link_to "マイページ", user_path(current_user), class: "nav-link" %>

            <%= link_to "ログアウト",
                destroy_user_session_path,
                data: { turbo_method: :delete },
                class: "nav-link" %>
          
          <% else %>
            <%= link_to "ログイン", new_user_session_path, class: "nav-link" %>
            <%= link_to "新規登録", new_user_registration_path, class: "nav-link" %>
          <% end %>
        </div>
      </div>
    </nav>
    
    <div class="container mt-3">

      <% if notice %> 
        <p style="color: green;"><%= notice %></p>
      <% end %>

      <% if alert %>
        <div class="alert alert-danger">
          <p style="color: red;"><%= alert %></p>
        </div>
      <% end %>
    </div>

    <main class="container mt-4">
      <%= yield %>
    </main>

    <footer class="border-top mt-5 py-3 bg-dark bg-opacity-75">
      <div class="container text-center text-white">
        <small>Copyright © 2026 Snowcom</small>
      </div>
    </footer>

  </body>
</html>
