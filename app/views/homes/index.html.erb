<div class="cover align-middle">
  <div>

    <h1>snowcom</h1>

    <% if user_signed_in? %>

      <p class="lead">ログイン中：<%= current_user.name %></p>

      <div class="mt-3">
        <%= link_to "コミュニティを見る", communities_path, class: "btn btn-success me-2" %>
        <%= button_to "ログアウト",
          destroy_user_session_path,
          method: :delete,
          class: "btn btn-danger d-inline" %>
      </div>

    <% else %>

      <p class="lead">スノースポーツ好きが集まるコミュニティSNS</p>

      <div class="mt-3">
        <%= link_to "新規登録", new_user_registration_path, class: "btn btn-success me-2" %>
        <%= link_to "ログイン", new_user_session_path, class: "btn btn-primary" %>
      </div>

    <% end %>
  </div>
</div>
