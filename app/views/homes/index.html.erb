<% content_for :full_width, true %>

<div class="cover d-flex align-items-center justify-content-center text-center">
  <div class="content-box">

    <h1 class="display-4 fw-bold mb-3">snowcom</h1>

    <% if user_signed_in? %>

      <p class="lead mb-4">
        ようこそ、<strong><%= current_user.name %></strong>さん
      </p>

      <div class="d-flex justify-content-center gap-3">
        <%= link_to "コミュニティを見る", communities_path, class: "btn btn-success px-4" %>
        <%= button_to "ログアウト",
          destroy_user_session_path,
          method: :delete,
          class: "btn btn-danger px-4" %>
      </div>

    <% else %>

      <p class="lead mb-4">
        スノースポーツ好きが集まるコミュニティSNS
      </p>

      <div class="d-flex justify-content-center gap-3">
        <%= link_to "新規登録", new_user_registration_path, class: "btn btn-primary px-4" %>
        <%= link_to "ログイン", new_user_session_path, class: "btn btn-outline-light px-4" %>
      </div>

    <% end %>

  </div>
</div>